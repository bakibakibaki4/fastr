# Copy to .env.local and fill in the values.

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase → Project Settings → API → "service_role" (SERVER-ONLY, keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Passcode to unlock the app
APP_PIN=1234

# Random string to sign the session cookie. Generate with:  openssl rand -hex 32
AUTH_SECRET=your-long-random-secret
